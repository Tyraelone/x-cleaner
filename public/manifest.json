{
  "manifest_version": 3,
  "name": "X Cleaner",
  "version": "0.1.9",
  "description": "Filter content on X with local rules and optional AI assistance.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://ark.cn-beijing.volces.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
